# =========================================================
# ASP.NET
# =========================================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# =========================================================
# PostgreSQL container
# Các biến này dùng cho service postgres trong docker-compose.yml
# =========================================================
POSTGRES_DB=ai_gateway
POSTGRES_USER=ai_gateway
POSTGRES_PASSWORD=change-me-local-password

# =========================================================
# Application connection strings
# Các biến này dùng cho service ai-gateway
# =========================================================
POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=ai_gateway;Username=ai_gateway;Password=change-me-local-password
REDIS_CONNECTION_STRING=redis:6379

# =========================================================
# AI Gateway
# AI_GATEWAY_ENCRYPTION_KEY_BASE64 phải là key 32 bytes dạng base64
# Tạo bằng: openssl rand -base64 32
# =========================================================
AI_GATEWAY_REQUIRE_CLIENT_AUTH=false
AI_GATEWAY_ENCRYPTION_KEY_BASE64=replace-with-32-byte-base64-key
AI_GATEWAY_METRIC_FLUSH_SECONDS=30
AI_GATEWAY_ERROR_EVENTS_RETENTION_DAYS=62
AI_GATEWAY_CONFIG_CACHE_SECONDS=60
AI_GATEWAY_ERROR_EVENTS_MAX_PER_ACCOUNT_TYPE_HOUR=20
AI_GATEWAY_DEFAULT_RESERVED_OUTPUT_TOKENS=1000
AI_GATEWAY_EXPOSE_ROUTING_WHEN_DEBUG=true

# =========================================================
# Admin Auth
# ADMIN_AUTH_API_KEY_HASH là SHA256(admin-key) rồi encode base64
# Linux/macOS:
# printf "your-admin-key" | openssl dgst -sha256 -binary | openssl base64
# =========================================================
ADMIN_AUTH_ENABLED=true
ADMIN_AUTH_API_KEY_HASH=replace-with-sha256-base64-hash
ADMIN_AUTH_ALLOW_IN_DEVELOPMENT_WITHOUT_KEY=false



# =============================================================
#
# API key cho từng account. Pattern: AI_ACCOUNT_KEY__<CODE_UPPERCASE>
# DataSeeder đọc các biến này lúc startup để encrypt và lưu vào DB.
#
# Nếu biến chưa set → account bị skip, seeder log warning.
# Nếu account đã có trong DB rồi → seeder không ghi đè (restart an toàn).
#
# Lấy key tại:
#   Gemini:      https://aistudio.google.com/app/apikey
#   Groq:        https://console.groq.com/keys
#   Mistral:     https://console.mistral.ai/api-keys
#   OpenRouter:  https://openrouter.ai/settings/keys
#   Fireworks:   https://fireworks.ai/api-keys
#   HuggingFace: https://huggingface.co/settings/tokens
# =============================================================
 
AI_ACCOUNT_KEY__GEMINI_ACC_01=AIzaSy_replace_with_real_key
AI_ACCOUNT_KEY__GROQ_ACC_01=gsk_replace_with_real_key
AI_ACCOUNT_KEY__MISTRAL_ACC_01=replace_with_real_key
AI_ACCOUNT_KEY__OPENROUTER_ACC_01=sk-or-replace_with_real_key
AI_ACCOUNT_KEY__FIREWORKS_ACC_01=fw_replace_with_real_key
AI_ACCOUNT_KEY__HF_ACC_01=hf_replace_with_real_token
 