{
  "ConnectionStrings": {
    "Postgres": "Host=127.0.0.1;Port=5432;Database=ai_gateway;Username=ai_gateway;Password=ai_gateway_local"
  },
  "Redis": {
    "ConnectionString": "127.0.0.1:6379"
  },
  "AiGateway": {
    "EncryptionKeyBase64": "",
    "BootstrapAdminEmail": "[email protected]",
    "BootstrapAdminPassword": "ChangeMe!2026",
    "MetricFlushSeconds": 30,
    "ErrorEventsRetentionDays": 62,
    "ConfigCacheSeconds": 60,
    "ErrorEventsMaxPerKeyTypeHour": 20,
    "DefaultReservedOutputTokens": 1000,
    "ExposeRoutingWhenDebug": true,
    "MaxRequestBodyBytes": 1048576,
    "HealthCheckIntervalMinutes": 5,
    "HealthCheckTimeoutMs": 10000
  },
  "Jwt": {
    "Issuer": "ai-gateway",
    "Audience": "ai-gateway",
    "SecretBase64": "",
    "AccessTokenMinutes": 60
  },
  "OpenRouter": {
    "AppReferer": "https://github.com/your-org/ai-gateway",
    "AppTitle": "AI Gateway"
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 1048576
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
